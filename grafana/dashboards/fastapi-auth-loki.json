{
  "title": "FastAPI Auth \u2014 Logs (Loki)",
  "uid": "fastapi-auth-loki",
  "tags": [
    "fastapi",
    "loki",
    "logs"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "label": "Data source",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "app",
        "type": "query",
        "label": "App",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": {
          "label": "app",
          "stream": "",
          "type": 1
        },
        "definition": "label_values(app)",
        "current": {
          "text": "fastapi-auth",
          "value": "fastapi-auth"
        },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "env",
        "type": "query",
        "label": "Env",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": {
          "label": "env",
          "stream": "{app=\"$app\"}",
          "type": 1
        },
        "definition": "label_values({app=\"$app\"}, env)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "level",
        "type": "query",
        "label": "Level",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": {
          "label": "level",
          "stream": "{app=\"$app\"}",
          "type": 1
        },
        "definition": "label_values({app=\"$app\"}, level)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total logs",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({app=\"$app\", env=~\"$env\"} [$__range]))",
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({app=\"$app\", env=~\"$env\", level=\"error\"} [$__range]))",
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Warnings",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({app=\"$app\", env=~\"$env\", level=\"warning\"} [$__range]))",
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requests",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({app=\"$app\", env=~\"$env\", logger=\"app.request\"} [$__range]))",
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Traffic & Latency",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Log volume by level",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum by (level) (count_over_time({app=\"$app\", env=~\"$env\"} [$__auto]))",
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "{{level}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests by status (per interval)",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum by (status) (count_over_time({app=\"$app\", env=~\"$env\", logger=\"app.request\"} | regexp `(?P<method>[A-Z]+) (?P<path>\\S+) from (?P<client>\\S+) -> (?P<status>\\d+) \\((?P<duration>[0-9.]+)ms\\)` [$__auto]))",
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Request latency",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "quantile_over_time(0.50, {app=\"$app\", env=~\"$env\", logger=\"app.request\"} | regexp `(?P<method>[A-Z]+) (?P<path>\\S+) from (?P<client>\\S+) -> (?P<status>\\d+) \\((?P<duration>[0-9.]+)ms\\)` | label_format method=\"\", path=\"\", client=\"\", status=\"\" | unwrap duration [$__auto])",
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "quantile_over_time(0.90, {app=\"$app\", env=~\"$env\", logger=\"app.request\"} | regexp `(?P<method>[A-Z]+) (?P<path>\\S+) from (?P<client>\\S+) -> (?P<status>\\d+) \\((?P<duration>[0-9.]+)ms\\)` | label_format method=\"\", path=\"\", client=\"\", status=\"\" | unwrap duration [$__auto])",
          "refId": "B",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "p90"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "quantile_over_time(0.99, {app=\"$app\", env=~\"$env\", logger=\"app.request\"} | regexp `(?P<method>[A-Z]+) (?P<path>\\S+) from (?P<client>\\S+) -> (?P<status>\\d+) \\((?P<duration>[0-9.]+)ms\\)` | label_format method=\"\", path=\"\", client=\"\", status=\"\" | unwrap duration [$__auto])",
          "refId": "C",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Top endpoints (by request count)",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "topk(10, sum by (path) (count_over_time({app=\"$app\", env=~\"$env\", logger=\"app.request\"} | regexp `(?P<method>[A-Z]+) (?P<path>\\S+) from (?P<client>\\S+) -> (?P<status>\\d+) \\((?P<duration>[0-9.]+)ms\\)` [$__range])))",
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "legendFormat": "{{path}}",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Logs",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "panels": []
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Application logs",
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "{app=\"$app\", env=~\"$env\", level=~\"$level\"}",
          "refId": "A",
          "queryType": "range",
          "editorMode": "code"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
