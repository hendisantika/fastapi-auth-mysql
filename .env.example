DATABASE_URL=mysql+pymysql://root:password@localhost:3306/fastapi_auth

# Generate a strong secret, e.g.: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Elastic APM (leave ELASTIC_APM_SERVER_URL empty to disable the agent)
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SERVICE_NAME=fastapi-auth-mysql
ELASTIC_APM_ENVIRONMENT=production
ELASTIC_APM_SERVICE_VERSION=1.0.0
# Provide ONE of the following (secret token OR API key) from Elastic Cloud:
ELASTIC_APM_SECRET_TOKEN=
ELASTIC_APM_API_KEY=
